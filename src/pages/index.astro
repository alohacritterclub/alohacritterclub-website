---
import Layout from '../layouts/Layout.astro';
import DonationAsk from '../components/DonationAsk.astro';
import home from '../content/home.json';
---
<Layout
  title="Aloha Critter Club | After-School Animal Clubs in Hawaii"
  description="Hawaii 501(c)(3) nonprofit building after-school clubs where kids become animal experts, practice SEL, and take action for local animal welfare."
>
  <section class="hero">
    <p class="tagline">{home.tagline}</p>
    <h1>{home.headline}</h1>
    <p class="lead">{home.subhead}</p>
  </section>

  <section class="video-section">
    <div class="video-wrap">
      <iframe
        src="https://www.youtube.com/embed/wOpa8_ZsdJk"
        title="Aloha Critter Club promo video"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>
  </section>

  <section class="stats">
    {home.stats.map(stat => (
      <div class="stat">
        <span class="stat-number">{stat.number}</span>
        <span class="stat-label">{stat.label}</span>
      </div>
    ))}
  </section>

  <section class="about-snippet">
    <h2>{home.what_we_do_heading}</h2>
    <p>{home.what_we_do_p1}</p>
    <p>{home.what_we_do_p2}</p>
    <p>
      <a href="/about">Meet the team →</a>
    </p>
  </section>

  <DonationAsk />
</Layout>

<style>
  .hero { padding: 2rem 0 1rem; }

  .tagline {
    font-style: italic;
    color: var(--color-accent);
    font-weight: 700;
    margin: 0 0 0.5rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.85rem;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1.5rem;
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    margin: 2rem 0;
    text-align: center;
  }

  .stat { display: flex; flex-direction: column; }

  .stat-number {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
  }

  .stat-label {
    color: var(--color-muted);
    font-size: 0.95rem;
    margin-top: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .video-section { margin: 2rem 0 0; }

  .video-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(45, 129, 166, 0.15);
  }

  .video-wrap iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
</style>
